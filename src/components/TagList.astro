---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="tags">
  {tags.map((tag) => <li>{tag}</li>)}
</ul>

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 14px 0 0;
    list-style: none;
  }

  .tags li {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.84rem;
    padding: 3px 11px;
    transition:
      color 180ms ease,
      background 180ms ease,
      border-color 180ms ease;
  }
</style>
