---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LearningCard from "../../components/LearningCard.astro";
import { collectGenreGroups } from "../../lib/genres";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return collectGenreGroups(posts).map((genre) => ({
    params: { slug: genre.slug },
    props: { genre },
  }));
}

const { genre } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={`题材：${genre.name}`} description={`按${genre.name}题材归档的每日写作学习日志。`}>
  <section class="hero hero-compact">
    <div class="hero-content">
      <p class="eyebrow">题材归档 / {genre.posts.length} 篇</p>
      <h1>{genre.name}</h1>
      <p>这些日志只保留抽象结构、章节功能、角色调度和文字执行规则，方便直接用于章纲诊断与正文修订。</p>
      <div class="hero-actions">
        <a class="button-link" href={`${base}genres/`}>返回题材分区</a>
        <a class="button-link secondary" href={`${base}posts/`}>查看全部日志</a>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>{genre.name}学习日志</h2>
    <div class="list-stack">
      {genre.posts.map((post) => <LearningCard post={post} />)}
    </div>
  </section>
</BaseLayout>
