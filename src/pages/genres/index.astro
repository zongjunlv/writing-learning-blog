---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectGenreGroups, getGenreHref } from "../../lib/genres";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const genreGroups = collectGenreGroups(posts);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="题材分区" description="按题材收纳每日男频玄幻写作学习日志。">
  <section class="hero hero-compact">
    <div class="hero-content">
      <h1>题材分区</h1>
      <p>把每日学习日志按题材、结构入口和写作问题收纳，新手可以从自己正在写的方向进入。</p>
    </div>
  </section>

  <section class="section genre-overview">
    <div class="genre-cloud genre-cloud-large">
      {genreGroups.map((genre) => (
        <a class="genre-chip" href={getGenreHref(base, genre.name)}>
          <span>{genre.name}</span>
          <strong>{genre.posts.length}</strong>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
