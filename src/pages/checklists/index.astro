---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const checklists = await getCollection("checklists");
---

<BaseLayout title="写作检查清单">
  <section class="hero">
    <p class="eyebrow">Checklists</p>
    <h1>写作检查清单</h1>
    <p>写完一章后，用这些清单检查目标、阻力、变化、钩子、段尾和句子完整性。</p>
  </section>
  <div class="grid">
    {checklists.map((checklist) => (
      <article class="panel">
        <h2>{checklist.data.title}</h2>
        <p class="muted">{checklist.data.summary}</p>
      </article>
    ))}
  </div>
</BaseLayout>
